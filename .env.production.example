# Production Environment Variables
# Copy this to .env.production and fill in the values

# Database (password used by docker-compose - generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=

# AI Model (REQUIRED)
KIMI_K2_API_KEY=your-kimi-k2-api-key

# API Authentication (REQUIRED - generate with: openssl rand -hex 64)
CHAT_API_KEY=

# Database URL (for API-only deployment with external DB)
# DATABASE_URL=postgresql://takumiai_agent:password@db.yourdomain.com:5434/takumiai_agent_db

# Valkey/Redis URL (for API-only deployment with external Valkey)
# VALKEY_URL=redis://:password@valkey.yourdomain.com:6381
